{
  "expo": {
    "name": "Samaj Connect",
    "slug": "samaj-connect",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "samajconnect",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.samajconnect.app"
    },
    "android": {
      "package": "com.samajconnect.app",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "apiUrl": "http://localhost:4000"
    }
  }
}
