# --- Runtime ---
NODE_ENV=development
PORT=4000

# --- Database (MongoDB Atlas M0) ---
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/samaj?retryWrites=true&w=majority

# --- Auth (JWT) ---
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=30d

# --- OTP ---
# When MOCK_OTP=true: skip real email, accept code "123456" for any phone. Dev only.
MOCK_OTP=true
OTP_TTL_MINUTES=10

# --- Email provider (Brevo or Resend) ---
EMAIL_PROVIDER=brevo
EMAIL_API_KEY=
EMAIL_FROM=Samaj Connect <noreply@example.com>

# --- Misc ---
# Shown on the "not registered" screen for users to contact the committee.
ADMIN_CONTACT_PHONE=+910000000000
